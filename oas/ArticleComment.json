          }
        },
        "security": [
          {
            "iam-oauth2-schema": [
              "Desk.articles.DELETE"
            ]
          }
        ],
        "x-audience": [
          "external-public"
        ]
      },
      "patch": {
        "tags": [
          "ArticleComment"
        ],
        "summary": "Update a translation comment",
        "description": "This API updates an existing article translation comment.",
        "operationId": "updateArticleTranslationComment",
        "parameters": [
          {
