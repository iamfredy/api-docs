        "parameters": [
          {
            "name": "feature",
            "in": "query",
            "description": "Feature, allowed values @businesshours@,@holidaylist@,@Skills@,@SkillType@,@workflows@,@blueprints@,@automationAlerts@,@fieldUpdates@,@automationTasks@,@customFunctions@",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "description": "Feature, allowed values @businesshours@,@holidaylist@,@Skills@,@SkillType@,@workflows@,@blueprints@,@automationAlerts@,@fieldUpdates@,@automationTasks@,@customFunctions@",
              "enum": [
                "workflows",
                "businesshours",
                "holidaylist",
                "blueprints",
                "Skills",
                "SkillType",
                "SupportPlans",
                "automationAlerts",
                "fieldUpdates",
                "automationTasks",
                "customFunctions"
              ]
            }
          },
          {
            "name": "departmentId",
            "in": "query",
            "description": "Department Id",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": [
                "string",
                "null",
                "integer"
              ],
              "format": "int64",
              "description": "Department Id"
            }
          },
          {
            "name": "module",
            "in": "query",
            "description": "Module, allowed values @tickets@,@contacts@,@contracts@,@accounts@,@tasks@,@products@,@timeEntry@,@events@,@calls@,@customModule@",
            "required": true,
            "style": "form",
            "explode": true,
