              "([0-9a-zA-Z_\\-\\.\\$@\\?\\,\\:\\'\\/\\!\\P{InBasicLatin}\\s])+": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 100,
                "minLength": 0
              }
            }
          }
        },
        "required": [
          "actionResult",
          "message",
          "status"
        ]
