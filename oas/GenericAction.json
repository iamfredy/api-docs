            "$ref": "#/components/responses/executeActionRespFinal"
          },
          "422": {
            "$ref": "./Common.json#/components/responses/invalidDataErrorResponse"
          },
          "500": {
            "$ref": "./Common.json#/components/responses/internalErrorResponse"
          }
        },
        "security": [
          {
            "oAuth2": [
              "settings.CREATE"
            ]
          }
        ],
        "x-audience": [
          "external-public"
        ]
      }
    }
  },
