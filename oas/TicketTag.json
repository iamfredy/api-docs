            "style": "form",
            "explode": true,
            "schema": {
              "type": [
                "string",
                "null"
              ],
              "description": "Key that sorts the tickets by a specific attribute: @dueDate@, @recentThread@, @createdTime@, or @ticketNumber@. The default sorting order is ascending. A - prefix denotes a descending order of sorting.",
