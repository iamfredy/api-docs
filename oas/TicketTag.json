  "paths": {
    "/api/v1/tickets/{ticketId}/tags": {
      "get": {
        "tags": [
          "TicketTag"
        ],
        "summary": "List tags in a ticket",
        "description": "This API lists tags associated with a ticket.",
        "operationId": "getTicketTags",
        "parameters": [
          {
            "$ref": "#/components/parameters/ticketId"
