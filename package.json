{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
 "scripts": {
  "generate": "node --import tsx/esm scripts/generate-docs.ts",
  "build": "npm run generate && next build",
  "dev": "npm run generate && next dev",
  "start": "next start",
  "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
  "postinstall": "fumadocs-mdx"
} ,
  "dependencies": {
    "fumadocs-core": "^16.6.7",
    "fumadocs-mdx": "^14.2.8",
    "fumadocs-openapi": "^10.3.13",
    "fumadocs-ui": "^16.6.7",
    "lucide-react": "^0.469.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^3.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
